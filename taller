<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Taller - Gestión de Campo Petrolero</title>
  <style>
    :root{
      --bg:#0b1020;
      --panel:#121a2f;
      --panel-2:#18233f;
      --line:rgba(255,255,255,.08);
      --text:#eaf0ff;
      --muted:#aab6d3;
      --soft:#8fa2c9;
      --accent:#7aa2ff;
      --accent-2:#4fd1c5;
      --gold:#d7b56d;
      --danger:#ff6b6b;
      --success:#7ee081;
      --shadow:0 20px 60px rgba(0,0,0,.35);
      --radius:20px;
      --radius-sm:14px;
      --max:1280px;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:Inter,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif;
      background:
        radial-gradient(circle at top left, rgba(122,162,255,.18), transparent 28%),
        radial-gradient(circle at top right, rgba(79,209,197,.10), transparent 24%),
        linear-gradient(180deg, #0a0f1d 0%, #0d1326 100%);
      color:var(--text);
      line-height:1.55;
    }

    .container{
      width:min(var(--max), calc(100% - 32px));
      margin:0 auto;
    }

    .topbar{
      position:sticky;
      top:0;
      z-index:30;
      backdrop-filter:blur(16px);
      background:rgba(9,14,28,.72);
      border-bottom:1px solid var(--line);
    }

    .topbar-inner{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      padding:14px 0;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:14px;
    }

    .brand-mark{
      width:42px;
      height:42px;
      border-radius:12px;
      background:linear-gradient(135deg, var(--gold), #8a6b2c);
      box-shadow:0 10px 30px rgba(215,181,109,.28);
    }

    .brand h1{
      margin:0;
      font-size:1rem;
      font-weight:700;
      letter-spacing:.02em;
    }

    .brand p{
      margin:2px 0 0;
      color:var(--muted);
      font-size:.88rem;
    }

    .actions{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
    }

    button{
      border:none;
      cursor:pointer;
      color:var(--text);
      background:linear-gradient(180deg, #1b2747, #141d36);
      border:1px solid rgba(255,255,255,.08);
      padding:11px 16px;
      border-radius:12px;
      font-weight:600;
      transition:.2s ease;
      box-shadow:var(--shadow);
    }

    button:hover{
      transform:translateY(-1px);
      border-color:rgba(122,162,255,.45);
    }

    .btn-primary{
      background:linear-gradient(135deg, var(--accent), #5b7cfa);
      color:white;
    }

    .btn-secondary{
      background:linear-gradient(135deg, #19304a, #13243b);
    }

    .btn-danger{
      background:linear-gradient(135deg, #482030, #31151f);
      color:#ffd8d8;
    }

    .hero{
      padding:42px 0 28px;
    }

    .hero-card{
      position:relative;
      overflow:hidden;
      border:1px solid var(--line);
      border-radius:28px;
      background:
        linear-gradient(135deg, rgba(255,255,255,.04), rgba(255,255,255,.02)),
        linear-gradient(180deg, rgba(16,24,44,.9), rgba(11,18,33,.95));
      box-shadow:var(--shadow);
      padding:38px;
    }

    .hero-card::before{
      content:"";
      position:absolute;
      inset:auto -60px -60px auto;
      width:220px;
      height:220px;
      background:radial-gradient(circle, rgba(122,162,255,.35), transparent 65%);
      pointer-events:none;
    }

    .hero-grid{
      display:grid;
      grid-template-columns:1.4fr .8fr;
      gap:24px;
      align-items:end;
    }

    .eyebrow{
      display:inline-flex;
      align-items:center;
      gap:10px;
      padding:8px 12px;
      border:1px solid rgba(215,181,109,.28);
      border-radius:999px;
      color:#f5dfaa;
      background:rgba(215,181,109,.08);
      font-size:.85rem;
      margin-bottom:16px;
    }

    .hero h2{
      margin:0 0 12px;
      font-size:clamp(2rem, 4vw, 3.4rem);
      line-height:1.08;
      letter-spacing:-.03em;
    }

    .hero p{
      margin:0;
      color:var(--muted);
      max-width:850px;
    }

    .hero-metrics{
      display:grid;
      grid-template-columns:1fr;
      gap:14px;
    }

    .metric{
      padding:18px;
      border-radius:18px;
      background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
      border:1px solid var(--line);
    }

    .metric span{
      display:block;
      color:var(--soft);
      font-size:.84rem;
      margin-bottom:8px;
    }

    .metric strong{
      font-size:1.2rem;
      letter-spacing:.02em;
    }

    .layout{
      display:grid;
      grid-template-columns:280px 1fr;
      gap:22px;
      padding:12px 0 48px;
    }

    aside{
      position:sticky;
      top:84px;
      align-self:start;
    }

    .side-card{
      border:1px solid var(--line);
      border-radius:24px;
      background:linear-gradient(180deg, rgba(18,26,47,.9), rgba(14,21,39,.96));
      box-shadow:var(--shadow);
      padding:18px;
    }

    .side-card h3{
      margin:0 0 10px;
      font-size:1rem;
    }

    .nav-links{
      display:grid;
      gap:8px;
    }

    .nav-links a{
      text-decoration:none;
      color:var(--muted);
      padding:10px 12px;
      border-radius:12px;
      transition:.2s ease;
      border:1px solid transparent;
    }

    .nav-links a:hover{
      color:var(--text);
      background:rgba(255,255,255,.04);
      border-color:var(--line);
    }

    .save-status{
      margin-top:14px;
      font-size:.9rem;
      color:var(--accent-2);
    }

    main{
      display:grid;
      gap:20px;
    }

    .card{
      border:1px solid var(--line);
      border-radius:24px;
      background:linear-gradient(180deg, rgba(18,26,47,.92), rgba(13,19,35,.96));
      box-shadow:var(--shadow);
      overflow:hidden;
    }

    .card-head{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:14px;
      padding:20px 24px;
      border-bottom:1px solid var(--line);
      background:linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.01));
    }

    .card-head h3{
      margin:0;
      font-size:1.08rem;
      letter-spacing:.01em;
    }

    .card-head p{
      margin:4px 0 0;
      color:var(--muted);
      font-size:.92rem;
    }

    .card-body{
      padding:24px;
    }

    .grid{
      display:grid;
      gap:16px;
    }

    .grid-2{
      grid-template-columns:repeat(2, minmax(0,1fr));
    }

    .grid-3{
      grid-template-columns:repeat(3, minmax(0,1fr));
    }

    .field{
      display:grid;
      gap:8px;
    }

    label{
      font-size:.92rem;
      color:#d8e1f7;
      font-weight:600;
    }

    .hint{
      color:var(--soft);
      font-size:.84rem;
      margin-top:-2px;
    }

    input, select, textarea{
      width:100%;
      border:1px solid rgba(255,255,255,.08);
      background:rgba(7,11,22,.5);
      color:var(--text);
      border-radius:14px;
      padding:13px 14px;
      outline:none;
      transition:.2s ease;
      font:inherit;
    }

    input:focus, select:focus, textarea:focus{
      border-color:rgba(122,162,255,.7);
      box-shadow:0 0 0 4px rgba(122,162,255,.12);
    }

    textarea{
      min-height:120px;
      resize:vertical;
    }

    .table-wrap{
      overflow:auto;
      border:1px solid var(--line);
      border-radius:18px;
    }

    table{
      width:100%;
      border-collapse:collapse;
      min-width:760px;
    }

    th, td{
      border-bottom:1px solid var(--line);
      padding:14px 14px;
      text-align:left;
      vertical-align:top;
    }

    th{
      color:#f2f6ff;
      background:rgba(255,255,255,.03);
      font-size:.92rem;
    }

    td{
      color:var(--muted);
      font-size:.94rem;
    }

    .section-note{
      margin:0 0 16px;
      color:var(--muted);
    }

    .pill{
      display:inline-block;
      padding:7px 10px;
      border-radius:999px;
      background:rgba(122,162,255,.12);
      border:1px solid rgba(122,162,255,.18);
      color:#dce7ff;
      font-size:.82rem;
      font-weight:600;
    }

    .summary-box{
      border:1px dashed rgba(215,181,109,.35);
      background:rgba(215,181,109,.06);
      border-radius:18px;
      padding:16px;
      color:#f4e6bf;
    }

    .footer-actions{
      display:flex;
      flex-wrap:wrap;
      gap:12px;
      justify-content:flex-end;
      margin-top:18px;
    }

    .small{
      font-size:.84rem;
      color:var(--soft);
    }

    .calc{
      display:grid;
      grid-template-columns:repeat(4, minmax(0,1fr));
      gap:16px;
    }

    .calc .field{
      background:rgba(255,255,255,.02);
      border:1px solid var(--line);
      border-radius:18px;
      padding:14px;
    }

    @media (max-width: 1080px){
      .layout{
        grid-template-columns:1fr;
      }
      aside{
        position:relative;
        top:0;
      }
      .hero-grid{
        grid-template-columns:1fr;
      }
    }

    @media (max-width: 760px){
      .grid-2, .grid-3, .calc{
        grid-template-columns:1fr;
      }
      .topbar-inner{
        flex-direction:column;
        align-items:flex-start;
      }
      .hero-card{
        padding:24px;
      }
      .card-body, .card-head{
        padding:18px;
      }
      .container{
        width:min(var(--max), calc(100% - 20px));
      }
    }

    @media print{
      body{
        background:white;
        color:black;
      }
      .topbar, aside, .footer-actions{
        display:none !important;
      }
      .layout{
        display:block;
      }
      .card{
        box-shadow:none;
        border:1px solid #ccc;
        background:white;
        break-inside:avoid;
        margin-bottom:16px;
      }
      .card-head, .card-body, .hero-card{
        background:white;
        color:black;
      }
      input, select, textarea{
        border:1px solid #aaa;
        background:white;
        color:black;
      }
      .table-wrap{
        border:1px solid #aaa;
      }
      th, td{
        border-color:#ccc;
        color:black;
      }
      .hero{
        padding-top:0;
      }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="container topbar-inner">
      <div class="brand">
        <div class="brand-mark"></div>
        <div>
          <h1>Taller de Gestión de Campo Petrolero</h1>
          <p>Formulario web editable para diligenciar directamente en el navegador</p>
        </div>
      </div>

      <div class="actions">
        <button class="btn-secondary" onclick="guardarManual()">Guardar</button>
        <button class="btn-secondary" onclick="exportarJSON()">Exportar JSON</button>
        <button class="btn-primary" onclick="window.print()">Imprimir / PDF</button>
        <button class="btn-danger" onclick="limpiarFormulario()">Restablecer</button>
      </div>
    </div>
  </header>

  <section class="hero">
    <div class="container">
      <div class="hero-card">
        <div class="hero-grid">
          <div>
            <div class="eyebrow">Procesos Industriales I · Actividad Formativa</div>
            <h2>Simulación de Gestión de Campo Petrolero</h2>
            <p>
              En esta actividad asumirás el rol de gerente de un proyecto de exploración y producción de petróleo,
              con un presupuesto asignado de 50.000.000 USD y decisiones estratégicas en exploración, perforación y extracción [file:1].
            </p>
          </div>

          <div class="hero-metrics">
            <div class="metric">
              <span>Presupuesto base</span>
              <strong>50.000.000 USD</strong>
            </div>
            <div class="metric">
              <span>Cadena analizada</span>
              <strong>Upstream</strong>
            </div>
            <div class="metric">
              <span>Modalidad</span>
              <strong>Formulario diligenciable</strong>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="container layout">
    <aside>
      <div class="side-card">
        <h3>Navegación</h3>
        <div class="nav-links">
          <a href="#datos">Datos generales</a>
          <a href="#contexto">Contexto teórico</a>
          <a href="#exploracion">Fase 1 · Exploración</a>
          <a href="#perforacion">Fase 2 · Perforación</a>
          <a href="#extraccion">Fase 3 · Extracción</a>
          <a href="#resultados">Resultados finales</a>
          <a href="#analisis">Preguntas de análisis</a>
          <a href="#comparacion">Comparación</a>
          <a href="#investigacion">Investigación</a>
          <a href="#reto">Reto adicional</a>
        </div>
        <div class="save-status" id="saveStatus">Guardado automático activo</div>
      </div>
    </aside>

    <main>
      <section class="card" id="datos">
        <div class="card-head">
          <div>
            <h3>Datos generales</h3>
            <p>Encabezado del estudiante y datos básicos del desarrollo del taller.</p>
          </div>
          <span class="pill">Editable</span>
        </div>
        <div class="card-body">
          <div class="grid grid-3">
            <div class="field">
              <label for="nombre">Nombre del estudiante</label>
              <input type="text" id="nombre" name="nombre" data-save />
            </div>
            <div class="field">
              <label for="codigo">Código</label>
              <input type="text" id="codigo" name="codigo" data-save />
            </div>
            <div class="field">
              <label for="grupo">Grupo</label>
              <input type="text" id="grupo" name="grupo" data-save />
            </div>
            <div class="field">
              <label for="docente">Docente</label>
              <input type="text" id="docente" name="docente" data-save />
            </div>
            <div class="field">
              <label for="fecha">Fecha</label>
              <input type="date" id="fecha" name="fecha" data-save />
            </div>
            <div class="field">
              <label for="presupuestoBase">Presupuesto asignado (USD)</label>
              <input type="number" id="presupuestoBase" name="presupuestoBase" value="50000000" data-save />
            </div>
          </div>
        </div>
      </section>

      <section class="card" id="contexto">
        <div class="card-head">
          <div>
            <h3>Contexto teórico</h3>
            <p>El taller se enfoca en el segmento upstream, desde la búsqueda del hidrocarburo hasta su producción en superficie [file:1].</p>
          </div>
          <span class="pill">Referencia</span>
        </div>
        <div class="card-body">
          <p class="section-note">
            La industria del petróleo se divide en upstream, midstream y downstream; esta actividad trabaja específicamente el upstream [file:1].
          </p>

          <h4>Exploración</h4>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Técnica</th>
                  <th>Descripción</th>
                  <th>Costo</th>
                  <th>Precisión</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Estudios geológicos básicos</td>
                  <td>Análisis de mapas, afloramientos rocosos y datos históricos [file:1].</td>
                  <td>Bajo ($1-5M) [file:1]</td>
                  <td>Baja (20-30%) [file:1]</td>
                </tr>
                <tr>
                  <td>Sísmica 2D + Gravimetría</td>
                  <td>Ondas sísmicas para perfiles del subsuelo, complementadas con estudios gravimétricos [file:1].</td>
                  <td>Medio ($5-12M) [file:1]</td>
                  <td>Media (40-55%) [file:1]</td>
                </tr>
                <tr>
                  <td>Sísmica 3D completa</td>
                  <td>Modelo volumétrico tridimensional del subsuelo, estándar de la industria [file:1].</td>
                  <td>Alto ($10-25M) [file:1]</td>
                  <td>Alta (65-80%) [file:1]</td>
                </tr>
              </tbody>
            </table>
          </div>

          <h4 style="margin-top:22px;">Perforación</h4>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Tipo de pozo</th>
                  <th>Descripción</th>
                  <th>Profundidad</th>
                  <th>Costo</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Pozo vertical</td>
                  <td>Perforación recta con broca tricónica o PDC [file:1].</td>
                  <td>2.000-3.500 m [file:1]</td>
                  <td>$3-8M [file:1]</td>
                </tr>
                <tr>
                  <td>Pozo direccional</td>
                  <td>Se desvía para alcanzar objetivos laterales y usa motor de fondo con MWD/LWD [file:1].</td>
                  <td>3.000-5.000 m [file:1]</td>
                  <td>$8-18M [file:1]</td>
                </tr>
                <tr>
                  <td>Pozo horizontal + fracking</td>
                  <td>Incluye sección horizontal de 1.000-2.000 m y fracturamiento multietapa [file:1].</td>
                  <td>4.000-6.000 m [file:1]</td>
                  <td>$15-30M [file:1]</td>
                </tr>
              </tbody>
            </table>
          </div>

          <h4 style="margin-top:22px;">Extracción y facilidades</h4>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Método</th>
                  <th>Descripción</th>
                  <th>Producción típica</th>
                  <th>Costo</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Flujo natural</td>
                  <td>La presión del yacimiento impulsa el petróleo; requiere separador bifásico básico [file:1].</td>
                  <td>200-1.000 BPD [file:1]</td>
                  <td>$2-5M [file:1]</td>
                </tr>
                <tr>
                  <td>Bombeo mecánico</td>
                  <td>Usa unidad de balancín, separador trifásico y deshidratador [file:1].</td>
                  <td>500-2.500 BPD [file:1]</td>
                  <td>$8-15M [file:1]</td>
                </tr>
                <tr>
                  <td>Recuperación mejorada (EOR)</td>
                  <td>Incluye inyección de agua o gas, bombeo electrosumergible y planta completa [file:1].</td>
                  <td>2.000-5.000+ BPD [file:1]</td>
                  <td>$15-25M [file:1]</td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="summary-box" style="margin-top:18px;">
            Dato clave: el documento indica que solo 1 de cada 5 pozos exploratorios resulta exitoso sin estudios geofísicos previos y que con sísmica 3D la tasa de éxito puede superar el 50% [file:1].
          </div>
        </div>
      </section>

      <section class="card" id="exploracion">
        <div class="card-head">
          <div>
            <h3>Fase 1 · Exploración</h3>
            <p>Primera decisión estratégica del proyecto [file:1].</p>
          </div>
          <span class="pill">Decisión 1</span>
        </div>
        <div class="card-body">
          <div class="grid grid-2">
            <div class="field">
              <label for="exp_p1">a) ¿Por qué una mayor inversión en exploración reduce el riesgo?</label>
              <textarea id="exp_p1" name="exp_p1" data-save></textarea>
            </div>
            <div class="field">
              <label for="exp_p2">b) ¿Qué opción elegiste y por qué?</label>
              <textarea id="exp_p2" name="exp_p2" data-save></textarea>
            </div>
          </div>

          <div class="grid grid-2" style="margin-top:16px;">
            <div class="field">
              <label for="exp_opcion">Opción seleccionada</label>
              <select id="exp_opcion" name="exp_opcion" data-save>
                <option value="">Seleccione</option>
                <option>Estudios geológicos básicos</option>
                <option>Sísmica 2D + Gravimetría</option>
                <option>Sísmica 3D completa</option>
              </select>
            </div>
            <div class="field">
              <label for="exp_resultado">Resultado</label>
              <select id="exp_resultado" name="exp_resultado" data-save>
                <option value="">Seleccione</option>
                <option>Éxito</option>
                <option>Parcial</option>
              </select>
            </div>
          </div>

          <div class="grid grid-3" style="margin-top:16px;">
            <div class="field">
              <label for="exp_costo">Costo de la inversión (M USD)</label>
              <input type="number" id="exp_costo" name="exp_costo" data-save data-calc />
            </div>
            <div class="field">
              <label for="exp_restante">Presupuesto restante (M USD)</label>
              <input type="number" id="exp_restante" name="exp_restante" data-save />
            </div>
            <div class="field">
              <label for="exp_reservas">Reservas estimadas (millones de barriles)</label>
              <input type="number" id="exp_reservas" name="exp_reservas" data-save />
            </div>
          </div>

          <div class="field" style="margin-top:16px;">
            <label for="exp_evento">Evento aleatorio e impacto</label>
            <textarea id="exp_evento" name="exp_evento" data-save></textarea>
          </div>
        </div>
      </section>

      <section class="card" id="perforacion">
        <div class="card-head">
          <div>
            <h3>Fase 2 · Perforación</h3>
            <p>Selección del tipo de pozo según el presupuesto restante y la exploración [file:1].</p>
          </div>
          <span class="pill">Decisión 2</span>
        </div>
        <div class="card-body">
          <div class="grid grid-2">
            <div class="field">
