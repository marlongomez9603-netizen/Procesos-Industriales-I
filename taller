  <script>
    const STORAGE_KEY = "taller_gestion_campo_petrolero_premium_v1";
    const saveStatus = document.getElementById("saveStatus");

    function getFields() {
      return document.querySelectorAll("[data-save]");
    }

    function guardarDatos() {
      const data = {};
      getFields().forEach(el => {
        data[el.id || el.name] = el.value;
      });
      localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
      actualizarEstado("Cambios guardados");
      calcularCampos();
    }

    function cargarDatos() {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) {
        calcularCampos();
        return;
      }
      try {
        const data = JSON.parse(raw);
        getFields().forEach(el => {
          const key = el.id || el.name;
          if (data[key] !== undefined) el.value = data[key];
        });
      } catch(e) {}
      calcularCampos();
    }

    function actualizarEstado(texto) {
      saveStatus.textContent = texto;
      clearTimeout(window.__saveTimer);
      window.__saveTimer = setTimeout(() => {
        saveStatus.textContent = "Guardado automático activo";
      }, 1800);
    }

    function guardarManual() {
      guardarDatos();
      alert("Los datos fueron guardados en este navegador.");
    }

    function limpiarFormulario() {
      const ok = confirm("Se borrarán todos los datos guardados de este formulario en el navegador.");
      if (!ok) return;
      localStorage.removeItem(STORAGE_KEY);
      getFields().forEach(el => el.value = "");
      const presupuesto = document.getElementById("presupuestoBase");
      if (presupuesto) presupuesto.value = 50000000;
      calcularCampos();
      actualizarEstado("Formulario restablecido");
    }

    function n(id) {
      const val = parseFloat(document.getElementById(id)?.value);
      return isNaN(val) ? 0 : val;
    }

    function money(v) {
      return new Intl.NumberFormat("es-CO", {
        style: "currency",
        currency: "USD",
        maximumFractionDigits: 2
      }).format(v || 0);
    }

    function number(v) {
      return new Intl.NumberFormat("es-CO", {
        maximumFractionDigits: 2
      }).format(v || 0);
    }

    function calcularCampos() {
      const produccion = n("res_produccion_final") || n("ext_bpd_final");
      const precio = n("res_precio");
      const costoOperativo = n("res_costo_operativo");
      const exp = n("exp_costo");
      const perf = n("perf_costo");
      const ext = n("ext_costo");

      const ingresoDiario = produccion * precio;
      const ingresoMensual = ingresoDiario * 30;
      const utilidadNeta = ingresoDiario - costoOperativo;
      const utilidadAnual = utilidadNeta * 365;
      const regaliasBpd = produccion * 0.12;
      const regaliasMesValor = regaliasBpd * precio * 30;
      const inversionSumada = exp + perf + ext;

      if (!n("res_ingreso_diario") && ingresoDiario > 0) {
        document.getElementById("res_ingreso_diario").value = ingresoDiario.toFixed(2);
      }
      if (!n("res_utilidad_neta") && utilidadNeta !== 0) {
        document.getElementById("res_utilidad_neta").value = utilidadNeta.toFixed(2);
      }
      if (!n("res_utilidad_anual") && utilidadAnual !== 0) {
        document.getElementById("res_utilidad_anual").value = (utilidadAnual / 1000000).toFixed(2);
      }
      if (!n("res_inversion_total") && inversionSumada > 0) {
        document.getElementById("res_inversion_total").value = inversionSumada.toFixed(2);
      }

      document.getElementById("calc_ingreso_mensual").value = money(ingresoMensual);
      document.getElementById("calc_regalias_bpd").value = number(regaliasBpd) + " bbl/día";
      document.getElementById("calc_regalias_mes").value = money(regaliasMesValor);
      document.getElementById("calc_inversion_sumada").value = number(inversionSumada) + " M USD";
    }

    function exportarJSON() {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) {
        alert("No hay datos guardados para exportar.");
        return;
      }
      const blob = new Blob([raw], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = "taller_gestion_campo_petrolero.json";
      a.click();
      URL.revokeObjectURL(url);
      actualizarEstado("Archivo JSON exportado");
    }

    getFields().forEach(el => {
      el.addEventListener("input", guardarDatos);
      el.addEventListener("change", guardarDatos);
    });

    document.addEventListener("DOMContentLoaded", cargarDatos);
    cargarDatos();
  </script>
